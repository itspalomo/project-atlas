#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

case "${1:-}" in
  up)
    docker compose up -d --build
    ;;
  down)
    docker compose down
    ;;
  logs)
    docker compose logs -f --tail=200 "${2:-}"
    ;;
  migrate)
    docker compose run --rm atlas-api node dist/db/migrate.js
    ;;
  seed)
    docker compose run --rm atlas-api node dist/db/seed.js
    ;;
  runtime)
    docker compose --profile runtime up -d --build hermes
    ;;
  webhook)
    docker compose --profile public-webhook up -d cloudflared
    ;;
  *)
    cat <<'USAGE'
Usage: scripts/atlasctl <command>

Commands:
  up        Start Atlas API and Postgres
  down      Stop services
  logs      Tail logs
  migrate   Run Postgres migrations
  seed      Seed users, agents, and WhatsApp allowlist
  runtime   Start Hermes runtime profile
  webhook   Start optional Cloudflare webhook tunnel
USAGE
    ;;
esac
