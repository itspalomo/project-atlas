#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done

ROOT_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
cd "$ROOT_DIR"

if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

command="${1:-help}"
shift || true

usage() {
  cat <<'USAGE'
Usage: atlas <command> [args]

Install and config:
  install       Run the full Atlas VPS installer
  configure    Open .env and ecosystem/atlas.yaml for editing
  init         Create local ecosystem/atlas.yaml
  apply        Apply ecosystem config, migrations, seeds, and profiles
  install-cli  Install/update /usr/local/bin/atlas symlink
  doctor       Check local runtime prerequisites and service status

Services:
  up|start     Start Atlas base services
  down|stop    Stop services
  restart      Restart Atlas API
  status       Show Compose status and API health
  logs [svc]   Tail logs, optionally for one service
  update       Pull latest repo changes and rerun install

Data/Hermes:
  migrate      Run Postgres migrations
  seed         Seed users, agents, and identity metadata
  profiles     Merge Hermes config.yaml settings and generate Atlas native skill, MCP, and honcho files
  runtime      Start Hermes runtime profile
  runtime-off  Stop Hermes runtime profile
  honcho       Clone/start self-hosted Honcho

Webhook:
  webhook       Publish Hermes WhatsApp webhook through Tailscale Funnel
  webhook-status
                Show Tailscale Funnel status
  webhook-off   Turn off the configured Funnel webhook path
USAGE
}

ensure_env() {
  if [[ ! -f .env && -f .env.example ]]; then
    cp .env.example .env
    chmod 600 .env
    echo "Created .env from .env.example."
  fi
}

api_health() {
  local port
  port="$(grep -E '^ATLAS_API_PORT=' .env 2>/dev/null | cut -d= -f2- || true)"
  port="${port:-3000}"

  if command -v curl >/dev/null 2>&1; then
    curl -fsS "http://127.0.0.1:${port}/health" || true
    echo
    curl -fsS "http://127.0.0.1:${port}/ready" || true
    echo
  fi
}

compose_cmd() {
  local runtime_compose="${HERMES_HOME_DIR:-$ROOT_DIR/data/hermes}/compose.runtime.yaml"
  if [[ -f "$runtime_compose" ]]; then
    docker compose -f compose.yaml -f "$runtime_compose" "$@"
  else
    docker compose "$@"
  fi
}

runtime_services() {
  compose_cmd --profile runtime config --services 2>/dev/null | grep '^hermes' || true
}

case "$command" in
  install)
    scripts/install.sh
    ;;
  configure|config)
    ensure_env
    "${EDITOR:-nano}" .env
    scripts/init-ecosystem.sh
    "${EDITOR:-nano}" "${ATLAS_ECOSYSTEM_CONFIG:-ecosystem/atlas.yaml}"
    echo "Run 'atlas apply' to apply identity, agent, memory, and profile changes."
    ;;
  install-cli)
    target="${ATLAS_CLI_PATH:-}"
    if [[ -z "$target" ]]; then
      if [[ "$(id -u)" -eq 0 || -w /usr/local/bin ]]; then
        target="/usr/local/bin/atlas"
      else
        target="${HOME:-$ROOT_DIR}/.local/bin/atlas"
      fi
    fi

    target_dir="$(dirname "$target")"
    use_sudo=""
    writable_path="$target_dir"
    while [[ ! -e "$writable_path" && "$writable_path" != "/" ]]; do
      writable_path="$(dirname "$writable_path")"
    done

    if [[ "$(id -u)" -ne 0 && ! -w "$writable_path" ]]; then
      use_sudo="sudo"
    fi

    $use_sudo mkdir -p "$target_dir"
    $use_sudo ln -sf "$ROOT_DIR/scripts/atlasctl" "$target"
    echo "Installed atlas CLI at $target."

    case ":$PATH:" in
      *":$target_dir:"*) ;;
      *) echo "Add $target_dir to PATH if the atlas command is not found." ;;
    esac
    ;;
  doctor)
    echo "Atlas root: $ROOT_DIR"
    [[ -f .env ]] && echo ".env: present" || echo ".env: missing"
    [[ -f "${ATLAS_ECOSYSTEM_CONFIG:-ecosystem/atlas.yaml}" ]] && echo "ecosystem config: present" || echo "ecosystem config: missing"
    command -v git >/dev/null 2>&1 && git --version || echo "git: missing"
    command -v docker >/dev/null 2>&1 && docker --version || echo "docker: missing"
    docker compose version 2>/dev/null || echo "docker compose: missing"
    if command -v tailscale >/dev/null 2>&1; then
      tailscale status --json 2>/dev/null | sed -n 's/.*"BackendState"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/tailscale: \1/p' | head -n 1
    else
      echo "tailscale: missing"
    fi
    compose_cmd ps 2>/dev/null || true
    api_health
    ;;
  up|start)
    compose_cmd up -d --build
    ;;
  down|stop)
    compose_cmd down
    ;;
  restart)
    compose_cmd up -d --build atlas-api
    ;;
  status)
    compose_cmd ps
    api_health
    ;;
  logs)
    if [[ -n "${1:-}" ]]; then
      compose_cmd logs -f --tail=200 "$1"
    else
      compose_cmd logs -f --tail=200
    fi
    ;;
  update)
    git pull --ff-only
    scripts/install.sh
    ;;
  migrate)
    docker compose run --rm atlas-api node dist/db/migrate.js
    ;;
  seed)
    docker compose run --rm atlas-api node dist/db/seed.js
    ;;
  apply)
    scripts/init-ecosystem.sh
    docker compose run --rm atlas-api node dist/db/migrate.js
    docker compose run --rm atlas-api node dist/db/seed.js
    scripts/init-hermes-profiles.sh
    docker compose up -d --build atlas-api
    ;;
  init)
    scripts/init-ecosystem.sh
    ;;
  honcho)
    scripts/install-honcho.sh
    ;;
  profiles)
    scripts/init-hermes-profiles.sh
    ;;
  runtime)
    scripts/init-hermes-profiles.sh
    compose_cmd --profile runtime up -d --build
    ;;
  runtime-off)
    services="$(runtime_services)"
    if [[ -n "$services" ]]; then
      # shellcheck disable=SC2086
      compose_cmd --profile runtime stop $services
    fi
    ;;
  webhook)
    scripts/setup-tailscale-funnel.sh
    ;;
  webhook-status)
    tailscale funnel status
    ;;
  webhook-off)
    scripts/setup-tailscale-funnel.sh off
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command"
    echo
    usage
    exit 1
    ;;
esac
