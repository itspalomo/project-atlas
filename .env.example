# Project Atlas deployment settings.
# Copy to .env on the VPS and fill secrets before running scripts/install.sh.

NODE_ENV=production
LOG_LEVEL=info
ATLAS_API_HOST=0.0.0.0
ATLAS_API_PORT=3000
ATLAS_PUBLIC_BASE_URL=https://atlas.example.com

# Bind Atlas API on the host. Keep 127.0.0.1; Tailscale Funnel can proxy localhost.
ATLAS_API_BIND=127.0.0.1

# Database used by Atlas for structured facts, approvals, audit logs, and identity routing.
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-generate-with-openssl
DATABASE_URL=postgres://atlas:change-me-generate-with-openssl@postgres:5432/atlas

# Self-serve ecosystem config. This file is generated by scripts/init-ecosystem.sh.
ATLAS_ECOSYSTEM_CONFIG=ecosystem/atlas.yaml

# WhatsApp Business Cloud API.
# The Graph API version is intentionally configurable so the deployment can be upgraded without code changes.
WHATSAPP_GRAPH_API_VERSION=v24.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=change-me-generate-with-openssl
WHATSAPP_SEND_UNAUTHORIZED_REPLY=false
WHATSAPP_REQUEST_TIMEOUT_MS=10000

# Runtime routing. Use "stub" until Hermes profile gateway URLs are ready.
ATLAS_RUNTIME_MODE=stub
HERMES_BASE_URL=http://hermes:8642
# Optional full endpoint template. Supports {profile} and {agentId}.
# HERMES_ENDPOINT_TEMPLATE=http://hermes:8642/profiles/{profile}/v1/chat/completions
HERMES_MODEL=hermes
HERMES_DASHBOARD_PORT=9119
HERMES_GATEWAY_PORT=8642

# Honcho memory. Atlas self-hosts Honcho and wires Hermes profiles to these workspaces.
HONCHO_SOURCE_DIR=./vendor/honcho
HONCHO_AUTO_UPDATE=false
HONCHO_BASE_URL=http://honcho-api:8000
HONCHO_API_KEY=
HONCHO_HOST_PORT=8000
HONCHO_AUTH_USE_AUTH=false
HONCHO_AUTH_JWT_SECRET=change-me-generate-with-openssl

# Optional. Leave blank when the selected Hermes/runtime auth provider handles model auth.
# Fill these only if your Honcho/Hermes mode expects provider keys from the Atlas env.
LLM_OPENAI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_GEMINI_API_KEY=

# iOS bridge bootstrap auth. Replace this before pairing a device.
ATLAS_BRIDGE_API_KEY=change-me-generate-with-openssl

# Optional Tailscale auth key for non-interactive VPS bootstrap.
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=project-atlas

# Tailscale Funnel for WhatsApp Cloud API webhook.
# Funnel must be enabled in your tailnet policy/admin console before this can succeed.
TAILSCALE_FUNNEL_PORT=443
TAILSCALE_FUNNEL_PATH=/webhooks/whatsapp
TAILSCALE_FUNNEL_TARGET=http://127.0.0.1:3000
