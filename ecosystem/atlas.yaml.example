version: 1

project:
  id: household
  name: Household Atlas

runtimeGroups:
  - id: default
    displayName: Default Hermes Runtime
    isolation: container

users:
  - id: member-one
    displayName: Member One
    identities: []

  - id: member-two
    displayName: Member Two
    identities: []

agents:
  - id: household
    displayName: Household Atlas
    type: shared
    runtimeGroup: default
    hermesProfile: household
    honchoWorkspace: household
    owners:
      - member-one
    members:
      - member-one
      - member-two
    skills:
      - household
      - planning
      - calendar
      - reminders
      - health
      - training
      - nutrition
      - location
      - memory
